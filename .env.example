# --- Required (Vercel + local) ---
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Speech Engine (local voice check-in only) ---
# Run ngrok http 3002, then npm run setup:speech-engine.
# The setup script writes SPEECH_ENGINE_WS_URL and SPEECH_ENGINE_ID for you.
SPEECH_ENGINE_WS_URL=
SPEECH_ENGINE_ID=
SPEECH_ENGINE_PORT=3002

# --- App ---
ALLOW_GUEST_JOURNAL=true
DEFAULT_USER_ID=demo-user
ELEVENLABS_VOICE_ID=

# --- Optional ---
APP_URL=http://localhost:3001
