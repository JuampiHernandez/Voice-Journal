# --- Required ---
ELEVENLABS_API_KEY=
OPENAI_API_KEY=

# --- Speech Engine (local voice check-in only) ---
# Run ngrok http 3002, then npm run setup:speech-engine.
# The setup script writes SPEECH_ENGINE_WS_URL and SPEECH_ENGINE_ID for you.
SPEECH_ENGINE_WS_URL=
SPEECH_ENGINE_ID=
SPEECH_ENGINE_PORT=3002

# --- App ---
DEFAULT_USER_ID=demo-user
ELEVENLABS_VOICE_ID=

# --- Optional ---
APP_URL=http://localhost:3001

# --- One-time migration only (copy your cloud data into data/voice-journal.db) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
