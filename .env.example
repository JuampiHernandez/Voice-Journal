# --- Required (Vercel + Railway + local) ---
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Speech Engine (voice check-in) ---
# Local: ngrok URL. Production: Railway public domain.
SPEECH_ENGINE_WS_URL=wss://YOUR-DOMAIN.up.railway.app/ws
SPEECH_ENGINE_ID=
# Local only (Railway sets PORT automatically):
SPEECH_ENGINE_PORT=3002

# --- App ---
ALLOW_GUEST_JOURNAL=true
DEFAULT_USER_ID=demo-user
ELEVENLABS_VOICE_ID=

# --- Optional ---
APP_URL=https://your-app.vercel.app
